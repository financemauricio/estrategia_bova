# Copy this file to .env and fill in the values.
# On Streamlit Cloud, add these keys in the Secrets panel (TOML format).

# Supabase — get from: Project Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# E-mail alerts (Gmail recommended: use an App Password, not your account password)
# How to create an App Password: https://myaccount.google.com/apppasswords
EMAIL_REMETENTE=seu_email@gmail.com
EMAIL_SENHA=abcd efgh ijkl mnop
EMAIL_DESTINATARIO=seu_email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
